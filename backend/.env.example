# FastAPI 连接 PostgreSQL 的地址。
# 用户名、密码、数据库名需要和服务器上的 PostgreSQL 配置一致。
DATABASE_URL=postgresql+psycopg://fridge:fridge_dev_password@127.0.0.1:5432/fridge2recipe

# OpenSearch 当前只用于可选的 /api/v1/admin/reindex。
# 如果暂时不安装 OpenSearch，搜索主链路仍可通过 PostgreSQL 跑通。
OPENSEARCH_URL=http://127.0.0.1:9200

API_PORT=8000
ADMIN_TOKEN=dev-token
SAMPLE_DATA_PATH=data/xiachufang/recipes_subset.jsonl

# 允许访问 API 的前端来源，多个地址用英文逗号分隔。例如：
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://your-server-ip:3000
CORS_ALLOWED_ORIGINS=

# DeepSeek 大模型配置。
# 请只在本机 .env 中填写真实 key，不要把真实 key 提交到 Git。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT_SECONDS=60

# 是否开启搜索结果大模型精排。关闭时自动使用 v2 规则排序。
RERANK_ENABLED=true
RERANK_TOP_K=10
RERANK_WEIGHT=0.35

# 是否开启详情页“智能改良版菜谱”生成接口。
LLM_ENHANCE_ENABLED=true

# 是否开启演示缓存。开启后，命中固定三组输入时可直接返回
# data/demo/full_flow_cases.json 中清洗好的搜索、rerank 和智能生成结果。
DEMO_CACHE_ENABLED=false
DEMO_CACHE_PATH=data/demo/full_flow_cases.json
