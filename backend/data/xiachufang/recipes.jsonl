{"id":"r0000001","name":"西班牙金枪鱼沙拉","dish":"金枪鱼沙拉","description":"清爽高蛋白沙拉，适合作为快手午餐。","ingredients":[{"raw":"超市罐头装半盒金枪鱼(in spring water)","name":"超市罐头装半盒金枪鱼"},{"raw":"2大片生菜","name":"生菜"},{"raw":"5个圣女果","name":"圣女果"},{"raw":"半根黄瓜","name":"黄瓜"},{"raw":"半个红柿椒","name":"红柿椒"},{"raw":"半个紫洋葱","name":"紫洋葱"},{"raw":"1个七成熟水煮蛋","name":"七成熟水煮蛋"},{"raw":"适量红酒醋","name":"红酒醋"},{"raw":"适量胡椒","name":"胡椒"},{"raw":"适量橄榄油","name":"橄榄油"}],"ingredient_names":["超市罐头装半盒金枪鱼","生菜","圣女果","黄瓜","红柿椒","紫洋葱","七成熟水煮蛋","红酒醋","胡椒","橄榄油"],"n_ingredients":10,"steps":["鸡蛋进水煮，七成熟捞出，同时准备其他蔬菜","生菜撕片，圣女果对半切，黄瓜滚刀，红柿椒和紫洋葱切丝，鸡蛋切块","金枪鱼沥干水分","撒胡椒，加入红酒醋和少许橄榄油","拌匀后装盘"],"n_steps":5}
{"id":"r0000002","name":"家常番茄炒蛋","dish":"番茄炒蛋","description":"经典家常快手菜，适合番茄和鸡蛋库存充足时优先推荐。","ingredients":[{"raw":"2个西红柿","name":"西红柿"},{"raw":"3枚鸡蛋","name":"鸡蛋"},{"raw":"少许小葱","name":"小葱"},{"raw":"适量盐","name":"盐"},{"raw":"少许白糖","name":"白糖"},{"raw":"适量食用油","name":"食用油"}],"ingredient_names":["西红柿","鸡蛋","小葱","盐","白糖","食用油"],"n_ingredients":6,"steps":["西红柿切块，小葱切末，鸡蛋打散","热锅放油，倒入鸡蛋炒至凝固后盛出","锅中补少许油，下西红柿炒出汁","倒回鸡蛋，加盐和白糖调味","撒小葱后出锅"],"n_steps":5}
{"id":"r0000003","name":"青椒肉丝","dish":"青椒肉丝","description":"下饭家常菜，适合有青椒和猪肉时搜索。","ingredients":[{"raw":"200克猪里脊肉","name":"猪里脊肉"},{"raw":"2个青椒","name":"青椒"},{"raw":"1勺生抽","name":"生抽"},{"raw":"少许老抽","name":"老抽"},{"raw":"1勺淀粉","name":"淀粉"},{"raw":"2瓣蒜","name":"蒜"},{"raw":"适量盐","name":"盐"},{"raw":"适量食用油","name":"食用油"}],"ingredient_names":["猪里脊肉","青椒","生抽","老抽","淀粉","蒜","盐","食用油"],"n_ingredients":8,"steps":["猪里脊肉切丝，加生抽、老抽和淀粉抓匀腌制","青椒切丝，蒜切末","热锅放油，下肉丝滑炒变色后盛出","锅中留底油，下蒜末和青椒翻炒","倒回肉丝，加盐调味后出锅"],"n_steps":5}
{"id":"r0000004","name":"土豆炖牛肉","dish":"土豆牛肉","description":"适合土豆、牛肉、胡萝卜组合的炖菜。","ingredients":[{"raw":"300克牛肉","name":"牛肉"},{"raw":"2个土豆","name":"土豆"},{"raw":"1根胡萝卜","name":"胡萝卜"},{"raw":"半个洋葱","name":"洋葱"},{"raw":"2勺生抽","name":"生抽"},{"raw":"1勺老抽","name":"老抽"},{"raw":"2片姜","name":"姜"},{"raw":"2个八角","name":"八角"},{"raw":"适量盐","name":"盐"}],"ingredient_names":["牛肉","土豆","胡萝卜","洋葱","生抽","老抽","姜","八角","盐"],"n_ingredients":9,"steps":["牛肉切块焯水，土豆和胡萝卜切块，洋葱切片","锅中放油，下姜片、洋葱和牛肉翻炒","加入生抽、老抽和八角炒香","加热水没过食材，小火炖煮","放入土豆和胡萝卜继续炖至软烂，加盐调味"],"n_steps":5}
{"id":"r0000005","name":"黄金蛋炒饭","dish":"蛋炒饭","description":"适合处理剩米饭、鸡蛋和少量配菜。","ingredients":[{"raw":"1碗剩米饭","name":"剩米饭"},{"raw":"2枚鸡蛋","name":"鸡蛋"},{"raw":"半根胡萝卜","name":"胡萝卜"},{"raw":"1根火腿肠","name":"火腿肠"},{"raw":"少许小葱","name":"小葱"},{"raw":"适量盐","name":"盐"},{"raw":"适量食用油","name":"食用油"}],"ingredient_names":["剩米饭","鸡蛋","胡萝卜","火腿肠","小葱","盐","食用油"],"n_ingredients":7,"steps":["剩米饭打散，鸡蛋打匀，胡萝卜和火腿肠切丁","锅中放油，先炒鸡蛋并划散","加入胡萝卜丁和火腿肠翻炒","倒入米饭炒散","加盐调味，撒小葱出锅"],"n_steps":5}
{"id":"r0000006","name":"凉拌黄瓜木耳","dish":"凉拌黄瓜","description":"清爽凉菜，适合黄瓜、木耳和蒜组合。","ingredients":[{"raw":"1根黄瓜","name":"黄瓜"},{"raw":"1把木耳","name":"木耳"},{"raw":"3瓣蒜","name":"蒜"},{"raw":"1勺生抽","name":"生抽"},{"raw":"1勺陈醋","name":"陈醋"},{"raw":"少许白糖","name":"白糖"},{"raw":"适量盐","name":"盐"},{"raw":"少许香油","name":"香油"}],"ingredient_names":["黄瓜","木耳","蒜","生抽","陈醋","白糖","盐","香油"],"n_ingredients":8,"steps":["木耳泡发后焯水，黄瓜拍碎切段","蒜切末","碗中加入生抽、陈醋、白糖、盐和香油调成料汁","黄瓜和木耳放入大碗","倒入料汁拌匀"],"n_steps":5}
{"id":"r0000007","name":"香菇青菜","dish":"香菇青菜","description":"简单素菜，适合搜索青菜、香菇。","ingredients":[{"raw":"300克青菜","name":"青菜"},{"raw":"6朵香菇","name":"香菇"},{"raw":"2瓣蒜","name":"蒜"},{"raw":"1勺蚝油","name":"蚝油"},{"raw":"适量盐","name":"盐"},{"raw":"适量食用油","name":"食用油"}],"ingredient_names":["青菜","香菇","蒜","蚝油","盐","食用油"],"n_ingredients":6,"steps":["青菜洗净，香菇切片，蒜切末","热锅放油，下蒜末炒香","加入香菇翻炒至变软","加入青菜快速翻炒","加蚝油和盐调味后出锅"],"n_steps":5}
{"id":"r0000008","name":"麻婆豆腐","dish":"麻婆豆腐","description":"微辣下饭菜，适合豆腐和肉末组合；不吃辣时应被排除或降级。","ingredients":[{"raw":"1盒嫩豆腐","name":"嫩豆腐"},{"raw":"100克猪肉末","name":"猪肉末"},{"raw":"1勺豆瓣酱","name":"豆瓣酱"},{"raw":"少许花椒粉","name":"花椒粉"},{"raw":"2瓣蒜","name":"蒜"},{"raw":"1勺生抽","name":"生抽"},{"raw":"1勺淀粉","name":"淀粉"},{"raw":"适量食用油","name":"食用油"}],"ingredient_names":["嫩豆腐","猪肉末","豆瓣酱","花椒粉","蒜","生抽","淀粉","食用油"],"n_ingredients":8,"steps":["豆腐切块，蒜切末，淀粉加水调成水淀粉","热锅放油，下猪肉末炒散","加入豆瓣酱和蒜末炒出红油","加入豆腐和少量清水煮几分钟","倒入水淀粉勾芡，撒花椒粉"],"n_steps":5}
{"id":"r0000009","name":"可乐鸡翅","dish":"鸡翅","description":"甜咸口鸡肉菜，适合鸡翅搜索。","ingredients":[{"raw":"8个鸡翅中","name":"鸡翅中"},{"raw":"1听可乐","name":"可乐"},{"raw":"2片姜","name":"姜"},{"raw":"1勺生抽","name":"生抽"},{"raw":"1勺老抽","name":"老抽"},{"raw":"适量盐","name":"盐"},{"raw":"少许食用油","name":"食用油"}],"ingredient_names":["鸡翅中","可乐","姜","生抽","老抽","盐","食用油"],"n_ingredients":7,"steps":["鸡翅两面划刀，焯水后沥干","锅中放少许油，下鸡翅煎至两面微黄","加入姜片、生抽和老抽翻炒","倒入可乐没过鸡翅","中小火收汁，加盐调味"],"n_steps":5}
{"id":"r0000010","name":"蒜蓉西兰花","dish":"西兰花","description":"低难度蔬菜菜谱，适合西兰花和蒜。","ingredients":[{"raw":"1颗西兰花","name":"西兰花"},{"raw":"4瓣蒜","name":"蒜"},{"raw":"1勺蚝油","name":"蚝油"},{"raw":"适量盐","name":"盐"},{"raw":"适量食用油","name":"食用油"}],"ingredient_names":["西兰花","蒜","蚝油","盐","食用油"],"n_ingredients":5,"steps":["西兰花切小朵，用盐水浸泡后焯水","蒜切末","热锅放油，下蒜末炒香","加入西兰花翻炒","加蚝油和盐调味"],"n_steps":5}
{"id":"r0000011","name":"紫菜蛋花汤","dish":"蛋花汤","description":"快手汤品，适合鸡蛋和紫菜组合。","ingredients":[{"raw":"2枚鸡蛋","name":"鸡蛋"},{"raw":"1小把紫菜","name":"紫菜"},{"raw":"少许虾皮","name":"虾皮"},{"raw":"少许小葱","name":"小葱"},{"raw":"适量盐","name":"盐"},{"raw":"少许香油","name":"香油"}],"ingredient_names":["鸡蛋","紫菜","虾皮","小葱","盐","香油"],"n_ingredients":6,"steps":["鸡蛋打散，小葱切末","锅中加水煮开，放入紫菜和虾皮","转小火淋入蛋液","加盐调味","出锅前滴香油并撒小葱"],"n_steps":5}
{"id":"r0000012","name":"鸡蛋火腿三明治","dish":"三明治","description":"适合早餐，测试面包、鸡蛋、火腿、生菜组合。","ingredients":[{"raw":"2片吐司","name":"吐司"},{"raw":"1枚鸡蛋","name":"鸡蛋"},{"raw":"2片火腿","name":"火腿"},{"raw":"2片生菜","name":"生菜"},{"raw":"2片黄瓜","name":"黄瓜"},{"raw":"适量沙拉酱","name":"沙拉酱"}],"ingredient_names":["吐司","鸡蛋","火腿","生菜","黄瓜","沙拉酱"],"n_ingredients":6,"steps":["鸡蛋煎熟，黄瓜切片，生菜洗净","吐司可按喜好烘烤","在吐司上铺生菜、火腿、鸡蛋和黄瓜","挤上沙拉酱","盖上另一片吐司后切开"],"n_steps":5}
